{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.crdeckbuilder.top"
        }
      ],
      "destination": "https://crdeckbuilder.top/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/arena/arena-:id(\\d+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=0, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
